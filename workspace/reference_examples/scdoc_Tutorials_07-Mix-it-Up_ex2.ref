=== EXAMPLE: scdoc_Tutorials_07-Mix-it-Up_ex2 ===

DESCRIPTION: A very_bright pure_tone sound, with complex oscillator character around 221 Hz, featuring punchy attack and dynamic envelope, with chaotic spectral movement, and filtered with resonant_steep_rolloff character.

CATEGORIES:
  attack_time: punchy
  brightness: very_bright
  crest_factor_db: dynamic
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: moderate
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 220.6358
  harmonic_decay_rate: -8.5993
  harmonic_regularity: 0.1342
  pitch_clarity: 123.4951
  inharmonicity: 0.0000
  type: complex
[filter]
  spectral_slope: -6.0100
  resonance_freq: 516.7969

SUPERCOLLIDER CODE:
// Title: 07. Mix it Up Example 2
// Author: SC Documentation
// URL: http://doc.sccode.org/Tutorials/Getting-Started/07-Mix-it-Up.html
// Tags: 07-Mix-it-Up, Tutorials
// ---
// --- Example 2 ---
// one channel
{ Mix.new([SinOsc.ar(440, 0, 0.2), Saw.ar(660, 0.2)]).postln }.play;

// combine two stereo arrays
(
{
    var a, b;
    a = [SinOsc.ar(440, 0, 0.2), Saw.ar(662, 0.2)];
    b = [SinOsc.ar(442, 0, 0.2), Saw.ar(660, 0.2)];
    Mix([a, b]).postln;
}.play;
)
