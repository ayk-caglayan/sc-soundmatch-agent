=== EXAMPLE: scdoc_Guides_Tour_of_UGens_ex35 ===

DESCRIPTION: A dark pure_tone sound, with complex oscillator character around 96 Hz, featuring instant attack and impulsive envelope, with chaotic spectral movement, filtered with resonant_steep_rolloff character, and spectrally sparse.

CATEGORIES:
  attack_time: instant
  brightness: dark
  crest_factor_db: impulsive
  envelope_flatness: moderate
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: sparse
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 96.0373
  harmonic_decay_rate: -8.2771
  harmonic_regularity: 0.2603
  pitch_clarity: 7.2072
  inharmonicity: 0.0002
  type: complex
[filter]
  spectral_slope: -11.3196
  resonance_freq: 1162.7930

SUPERCOLLIDER CODE:
// Title: Tour of UGens Example 35
// Author: SC Documentation
// URL: http://doc.sccode.org/Guides/Tour_of_UGens.html
// Tags: Tour_of_UGens, Guides
// ---
// --- Example 35 ---
{ Klank.ar(`[[200, 671, 1153, 1723], nil, [1, 1, 1, 1]], Impulse.ar(2, 0, 0.1)) }.play;

{ Klank.ar(`[[200, 671, 1153, 1723], nil, [1, 1, 1, 1]], Dust.ar(8, 0.1)) }.play;

{ Klank.ar(`[[200, 671, 1153, 1723], nil, [1, 1, 1, 1]], PinkNoise.ar(0.007)) }.play;

{ Klank.ar(`[ {exprand(200, 4000)}.dup(12), nil, nil ], PinkNoise.ar(0.007)) }.play;

{ Klank.ar(`[ (1..13)*200, 1/(1..13), nil ], PinkNoise.ar(0.01)) }.play;

{ Klank.ar(`[ (1,3..13)*200, 1/(1,3..13), nil ], PinkNoise.ar(0.01)) }.play;
