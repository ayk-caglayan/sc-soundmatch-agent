=== EXAMPLE: scdoc_Guides_Tour_of_UGens_ex54 ===

DESCRIPTION: A very_bright noisy sound, with noise characteristics, featuring very_slow attack and impulsive envelope, with chaotic spectral movement, filtered with highpass character, and spectrally dense.

CATEGORIES:
  attack_time: very_slow
  brightness: very_bright
  crest_factor_db: impulsive
  envelope_flatness: very_dynamic
  harmonic_to_noise_ratio: noisy
  spectral_complexity_mean: dense
  spectral_flux_normalized: chaotic
  spectral_slope: highpass
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 0.0000
  harmonic_decay_rate: 0.0000
  harmonic_regularity: 0.0000
  pitch_clarity: 0.7699
  inharmonicity: 0.0000
  type: noise
[filter]
  spectral_slope: 0.0208
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: Tour of UGens Example 54
// Author: SC Documentation
// URL: http://doc.sccode.org/Guides/Tour_of_UGens.html
// Tags: Tour_of_UGens, Guides
// ---
// --- Example 54 ---
// used as an echo.
{ CombN.ar(Decay.ar(Dust.ar(1,0.5), 0.2, WhiteNoise.ar), 0.2, 0.2, 3) }.play;

// Comb used as a resonator. The resonant fundamental is equal to
// reciprocal of the delay time.
{ CombN.ar(WhiteNoise.ar(0.02), 0.01, XLine.kr(0.0001, 0.01, 20), 0.2) }.play;

{ CombL.ar(WhiteNoise.ar(0.02), 0.01, XLine.kr(0.0001, 0.01, 20), 0.2) }.play;

{ CombC.ar(WhiteNoise.ar(0.02), 0.01, XLine.kr(0.0001, 0.01, 20), 0.2) }.play;

// with negative feedback:
{ CombN.ar(WhiteNoise.ar(0.02), 0.01, XLine.kr(0.0001, 0.01, 20), -0.2) }.play;

{ CombL.ar(WhiteNoise.ar(0.02), 0.01, XLine.kr(0.0001, 0.01, 20), -0.2) }.play;

{ CombC.ar(WhiteNoise.ar(0.02), 0.01, XLine.kr(0.0001, 0.01, 20), -0.2) }.play;

{ CombC.ar(Decay.ar(Dust.ar(1,0.1), 0.2, WhiteNoise.ar), 1/100, 1/100, 3) }.play;
{ CombC.ar(Decay.ar(Dust.ar(1,0.1), 0.2, WhiteNoise.ar), 1/200, 1/200, 3) }.play;
{ CombC.ar(Decay.ar(Dust.ar(1,0.1), 0.2, WhiteNoise.ar), 1/300, 1/300, 3) }.play;
{ CombC.ar(Decay.ar(Dust.ar(1,0.1), 0.2, WhiteNoise.ar), 1/400, 1/400, 3) }.play;
