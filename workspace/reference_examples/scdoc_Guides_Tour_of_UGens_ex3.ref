// cubic approximation of sine
{ LFCub.ar(LFCub.kr(LFCub.kr(0.2,0,8,10),0, 400,800),0,0.1) }.play;
{ LFCub.ar(LFCub.kr(0.2, 0, 400,800),0,0.1) }.play;
{ LFCub.ar(800,0,0.1) }.play;
{ LFCub.ar(XLine.kr(100,15000,6),0,0.1) }.play;
