// --- Example 4 ---
{ LFTri.ar(LFTri.kr(LFTri.kr(0.2,0,8,10),0, 400,800),0,0.1) }.play;
{ LFTri.ar(LFTri.kr(0.2, 0, 400,800),0,0.1) }.play;
{ LFTri.ar(800,0,0.1) }.play;
{ LFTri.ar(XLine.kr(100,15000,6),0,0.1) }.play;
