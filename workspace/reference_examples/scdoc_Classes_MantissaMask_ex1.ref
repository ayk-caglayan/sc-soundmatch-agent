=== EXAMPLE: scdoc_Classes_MantissaMask_ex1 ===

DESCRIPTION: A bright pure_tone sound, with fm_or_inharmonic oscillator character around 503 Hz, featuring punchy attack and compressed envelope, with chaotic spectral movement, filtered with steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: punchy
  brightness: bright
  crest_factor_db: compressed
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 502.5171
  harmonic_decay_rate: -1.1153
  harmonic_regularity: 0.5711
  pitch_clarity: 162.1092
  inharmonicity: 0.5646
  type: fm_or_inharmonic
[filter]
  spectral_slope: -2.2162
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: MantissaMask Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/MantissaMask.html
// Tags: MantissaMask, Classes
// ---
// --- Example 1 ---
// preserve only 3 bits of mantissa.
{ MantissaMask.ar(SinOsc.ar(SinOsc.kr(0.2, 0, 400, 500), 0, 0.4), 3) }.play

// the original
{ SinOsc.ar(SinOsc.kr(0.2, 0, 400, 500), 0, 0.4) }.play

// the difference.
(
{
    var in;
    in = SinOsc.ar(SinOsc.kr(0.2, 0, 400, 500), 0, 0.4);
    in - MantissaMask.ar(in, 3)
}.play
)


// preserve 7 bits of mantissa.
// This makes the lower 16 bits of the floating point number become zero.
{ MantissaMask.ar(SinOsc.ar(SinOsc.kr(0.2, 0, 400, 500), 0, 0.4), 7) }.play

// the original
{ SinOsc.ar(SinOsc.kr(0.2, 0, 400, 500), 0, 0.4) }.play

// the difference.
(
{
    var in;
    in = SinOsc.ar(SinOsc.kr(0.2, 0, 400, 500), 0, 0.4);
    in - MantissaMask.ar(in, 7)
}.play
)
