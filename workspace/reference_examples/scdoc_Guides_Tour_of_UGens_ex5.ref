{ LFSaw.ar(LFSaw.kr(LFSaw.kr(0.2,0,8,10),0, 400,800),0,0.1) }.play;
{ LFSaw.ar(LFSaw.kr(0.2, 0, 400,800),0,0.1) }.play;
{ LFSaw.ar(100,0,0.1) }.play;
{ LFSaw.ar(XLine.kr(100,15000,6),0,0.1) }.play;
