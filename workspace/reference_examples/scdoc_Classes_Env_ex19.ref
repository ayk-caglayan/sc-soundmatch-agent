=== EXAMPLE: scdoc_Classes_Env_ex19 ===

DESCRIPTION: A very_dark pure_tone sound, with fm_or_inharmonic oscillator character around 337 Hz, featuring punchy attack and sustained envelope, with chaotic spectral movement, filtered with steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: punchy
  brightness: very_dark
  crest_factor_db: sustained
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 337.3328
  harmonic_decay_rate: -7.2083
  harmonic_regularity: 0.7402
  pitch_clarity: 96.6074
  inharmonicity: 0.3868
  type: fm_or_inharmonic
[filter]
  spectral_slope: -6.6980
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: Env Example 19
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/Env.html
// Tags: Env, Classes, envelope
// ---
// --- Example 19 ---
( // Plot the envelope using *circle and -circle
var loopBackTime = 0.06;
{ [
    EnvGen.kr(
        Env.circle([0.5, 1, 0.3], [0.01, 0.03, loopBackTime])
    ),
    EnvGen.kr(
        Env.new([0.5, 1, 0.3], [0.01, 0.03]).circle(loopBackTime)
    )
] }.plot(0.1 * 4 - 0.01).plotMode_(\dlines)
)

// A sound example
{ SinOsc.ar(EnvGen.kr(Env.circle([0, 1, 0], [0.01, 0.5, 0.2])) * 440 + 200) * 0.2 }.play;

// Times are repeated if times.size < levels.size
{ SinOsc.ar(EnvGen.kr(Env.circle([0, 1, 0, 2, 0, 1, 0], [0.01, 0.3])) * 440 + 200) * 0.2 }.play;

( // Multichannel expansion of levels
{ SinOsc.ar(EnvGen.kr(Env.circle(
    [0, 1, 0, 0.5 * (1..4), 0, 2.sqrt/2 * (1..4), 0],
    [0.01, 0.3]
)) * 440 + 200).clump(2).collect(_.sum) * 0.2
}.play;
)
