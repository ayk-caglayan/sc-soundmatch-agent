=== EXAMPLE: scdoc_Classes_OteyPiano_ex1 ===

DESCRIPTION: A very_dark pure_tone sound, with complex oscillator character around 50 Hz, featuring punchy attack and impulsive envelope, with chaotic spectral movement, energy distribution is front_heavy, filtered with steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: punchy
  brightness: very_dark
  crest_factor_db: impulsive
  envelope_flatness: very_dynamic
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: front_heavy

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 50.2896
  harmonic_decay_rate: 5.7250
  harmonic_regularity: 0.4824
  pitch_clarity: 39.6444
  inharmonicity: 0.0025
  type: complex
[filter]
  spectral_slope: -10.6388
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: OteyPiano Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/OteyPiano.html
// Tags: OteyPiano, Classes
// ---
// --- Example 1 ---
(
x = {OteyPiano.ar(50,0.5)}.play;
)
x.free;

//Define piano synthdef
(
SynthDef(\help_oteypiano, { |out=0, freq=440,gate=1, amp=0.5,rho=1|
    var son = OteyPiano.ar(freq, amp, rho:rho)*EnvGen.ar(Env.asr(0,1,0.1),gate,doneAction:2);
    Out.ar(out, Pan2.ar(son * 0.1, LinLin.kr(freq,36.midicps,90.midicps,-0.75,0.75)));
}).add;
)

//Use it.
(
Pbind(
    \instrument, \help_oteypiano,
    \delta, 1,
    \dur, 3,
    \degree, Pseq([1,3,5], inf),
    \rho, Pwhite(0.1,3) //comment this line to get standard sound
).play;
)
