=== EXAMPLE: scdoc_Classes_Metro_ex1 ===

DESCRIPTION: A very_dark pure_tone sound, with complex oscillator character around 441 Hz, featuring punchy attack and percussive envelope, with chaotic spectral movement, filtered with steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: punchy
  brightness: very_dark
  crest_factor_db: percussive
  envelope_flatness: moderate
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 441.2715
  harmonic_decay_rate: -12.5814
  harmonic_regularity: 0.5226
  pitch_clarity: 11.9450
  inharmonicity: 0.0056
  type: complex
[filter]
  spectral_slope: -4.2431
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: Metro Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/Metro.html
// Tags: Metro, Classes
// ---
// --- Example 1 ---
a = {Metro.ar(60, 1)}.play
a.free;

a = {Decay.kr(Metro.kr(XLine.kr(60, 120, 5), 1)) * SinOsc.ar(440, 0, 0.1)}.play;
a.free;

(
a = {
    Decay.kr(
        Metro.kr(
            LFNoise2.kr(0.2).range(30, 240),
            Dseq([1, 0.25, 0.5, 0.25], inf))) *
    SinOsc.ar(440, 0, 0.1)
    }.play;
)

a.free;
