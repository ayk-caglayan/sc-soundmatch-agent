=== EXAMPLE: scdoc_Guides_MoreChaos_ex1 ===

DESCRIPTION: A very_dark pure_tone sound, with fm_or_inharmonic oscillator character around 1442 Hz, featuring very_slow attack and percussive envelope, with chaotic spectral movement, filtered with steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: very_slow
  brightness: very_dark
  crest_factor_db: percussive
  envelope_flatness: dynamic
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 1442.0007
  harmonic_decay_rate: -2.8807
  harmonic_regularity: 0.7984
  pitch_clarity: 14.9387
  inharmonicity: 0.4868
  type: fm_or_inharmonic
[filter]
  spectral_slope: -9.0684
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: More chaos Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Guides/MoreChaos.html
// Tags: MoreChaos, Guides
// ---
// --- Example 1 ---
{ Henon2DC.ar(440, 1880, LFNoise2.kr(1, 0.1, 1.3), 0.3).dup }.play
{ Gbman2DL.ar(200, 800).dup }.play

// each also has a corresponding trigger
{ Ringz.ar(StandardTrig.ar(10, 20), 2205, 0.02).fold2(0.5).dup }.play

// can be k-rate
{ SinOsc.ar(Latoocarfian2DN.kr(4, 16, mul:220, add:440)).cubed.fold2(0.6).dup }.play

// trig & oscillator
(
{
var trig, sig;
trig=LatoocarfianTrig.kr(4, 12, [1.1, 1.5]);
sig=Latoocarfian2DC.ar(420, 8200, Lag.kr(TRand.kr(0.4, 0.8, trig), 0.1), Lag.kr(TRand.kr(2.0, 3.0, trig), 0.1), d:[1.0, 1.05], mul:Latch.kr(trig, trig));
(sig.cubed * 2).tanh
}.play
)
