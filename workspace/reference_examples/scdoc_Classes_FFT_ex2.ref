=== EXAMPLE: scdoc_Classes_FFT_ex2 ===

DESCRIPTION: A dark pure_tone sound, with complex oscillator character around 800 Hz, featuring very_slow attack and dynamic envelope, with chaotic spectral movement, filtered with resonant_steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: very_slow
  brightness: dark
  crest_factor_db: dynamic
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 800.0000
  harmonic_decay_rate: -12.0926
  harmonic_regularity: 0.5055
  pitch_clarity: 159.5802
  inharmonicity: 0.0514
  type: complex
[filter]
  spectral_slope: -7.0570
  resonance_freq: 818.2617

SUPERCOLLIDER CODE:
// Title: FFT Example 2
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/FFT.html
// Tags: FFT, Classes, spectral
// ---
// --- Example 2 ---
(
{
    var in, chain;
    in = WhiteNoise.ar(0.1);
    chain = FFT(LocalBuf(2048), in);
    IFFT(chain) // inverse FFT
}.play;
)

// inspecting it, we see that the chain is an FFT:
(
{
    var in, chain;
    in = WhiteNoise.ar(0.1);
    chain = FFT(LocalBuf(2048), in);
    chain.inspect; 
    IFFT(chain) // inverse FFT
}.play;
)

(
{
    var in, chain;
    in = SinOsc.ar(SinOsc.kr(SinOsc.kr(0.08, 0, 6, 6.2).squared, 0, 100, 800));
    chain = FFT(LocalBuf(2048), in);
    IFFT(chain)
}.play;
)

(
{
    var in, chain;
    in = SinOsc.ar(SinOsc.kr(SinOsc.kr(0.08, 0, 6, 6.2).squared, 0, 100, 800));
    // in = WhiteNoise.ar(0.2);
    chain = FFT(LocalBuf(2048), in);
    chain = PV_MagAbove(chain, 310);
    0.5 * IFFT(chain);
}.play;
)

(
{
    var in, chain;
    in = WhiteNoise.ar(0.2);
    chain = FFT(LocalBuf(2048), in);
    chain = PV_BrickWall(chain, SinOsc.kr(0.1));
    IFFT(chain)
}.play;
)

(
{
    var in, chain;
    in = WhiteNoise.ar(0.8);
    chain = FFT(LocalBuf(2048), in);
    chain = PV_RandComb(chain, 0.95, Impulse.kr(0.4));
    IFFT(chain)
}.play;
)

(
{
    var in, chain;
    in = WhiteNoise.ar(0.2);
    chain = FFT(LocalBuf(2048), in);
    chain = PV_RectComb(chain, 8, LFTri.kr(0.097, 0, 0.4, 0.5),
        LFTri.kr(0.24, 0, -0.5, 0.5));
    IFFT(chain)
}.play;
)

(
{
    var in, chain;
    in = SinOsc.ar(LFNoise1.kr(5.2, 250, 400));
    chain = FFT(LocalBuf(2048), in);
    // moves in and out of freeze
    chain = PV_MagFreeze(chain, SinOsc.kr(0.2));
    0.5 * IFFT(chain);
}.play;
)


// stereo example:

(
{
    var in, chain;
    in = SinOsc.ar(LFNoise1.kr([5.2, 3.3], 250, 400));
    chain = FFT({ LocalBuf(2048) } ! 2, in); // we need two buffers for stereo input.
    // moves in and out of freeze
    chain = PV_MagFreeze(chain, SinOsc.kr([0.2, 0.3]));
    0.5 * IFFT(chain);
}.play;
)
