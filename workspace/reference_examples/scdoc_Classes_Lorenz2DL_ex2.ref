=== EXAMPLE: scdoc_Classes_Lorenz2DL_ex2 ===

DESCRIPTION: A very_dark mixed sound, with fm_or_inharmonic oscillator character around 153 Hz, featuring slow attack and percussive envelope, with chaotic spectral movement, and filtered with steep_rolloff character.

CATEGORIES:
  attack_time: slow
  brightness: very_dark
  crest_factor_db: percussive
  envelope_flatness: flat
  harmonic_to_noise_ratio: mixed
  spectral_complexity_mean: moderate
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 152.8913
  harmonic_decay_rate: -3.8492
  harmonic_regularity: 0.7680
  pitch_clarity: 14.6727
  inharmonicity: 0.1070
  type: fm_or_inharmonic
[filter]
  spectral_slope: -33.0805
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: Lorenz2DL Example 2
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/Lorenz2DL.html
// Tags: Lorenz2DL, Classes
// ---
// --- Example 2 ---
{ Lorenz2DL.ar(11025, 44100) }.play(s);

// randomly modulate params
(
{ Lorenz2DL.ar(
    11025, 44100,
    LFNoise0.kr(1, 2, 10),
    20,
    LFNoise0.kr(1, 1.5, 2),
    0.02
) * 0.2 }.play(s);
)

// as a frequency control
{ SinOsc.ar(Lorenz2DL.ar(40, 80, h:0.02)*800+900)*0.4 }.play(s);
