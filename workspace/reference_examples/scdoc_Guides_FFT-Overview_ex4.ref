=== EXAMPLE: scdoc_Guides_FFT-Overview_ex4 ===

DESCRIPTION: A very_bright clean sound, with complex characteristics, featuring moderate attack and percussive envelope, with chaotic spectral movement, filtered with resonant_highpass character, and spectrally rich.

CATEGORIES:
  attack_time: moderate
  brightness: very_bright
  crest_factor_db: percussive
  envelope_flatness: flat
  harmonic_to_noise_ratio: clean
  spectral_complexity_mean: rich
  spectral_flux_normalized: chaotic
  spectral_slope: highpass
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 0.0000
  harmonic_decay_rate: 0.0000
  harmonic_regularity: 0.0000
  pitch_clarity: 11.7493
  inharmonicity: 0.0000
  type: complex
[filter]
  spectral_slope: 6.8015
  resonance_freq: 344.5312

SUPERCOLLIDER CODE:
// Title: FFT Overview Example 4
// Author: SC Documentation
// URL: http://doc.sccode.org/Guides/FFT-Overview.html
// Tags: FFT-Overview, Guides, spectral
// ---
// --- Example 4 ---
(
{
  var in, chain;
    in = WhiteNoise.ar(0.8);
    chain = FFT(LocalBuf(2048), in); // encode to frequency domain
    chain = PV_RandComb(chain, 0.95, Impulse.kr(0.4)); // process
    IFFT(chain) // decode to time domain
}.play;
)
