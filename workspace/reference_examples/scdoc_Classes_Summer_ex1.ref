=== EXAMPLE: scdoc_Classes_Summer_ex1 ===

DESCRIPTION: A very_dark pure_tone sound, with fm_or_inharmonic oscillator character around 101 Hz, featuring punchy attack and sustained envelope, with chaotic spectral movement, filtered with resonant_steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: punchy
  brightness: very_dark
  crest_factor_db: sustained
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 100.5793
  harmonic_decay_rate: -5.9365
  harmonic_regularity: 0.6419
  pitch_clarity: 38.2251
  inharmonicity: 0.2708
  type: fm_or_inharmonic
[filter]
  spectral_slope: -7.0192
  resonance_freq: 215.3320

SUPERCOLLIDER CODE:
// Title: Summer Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/Summer.html
// Tags: Summer, Classes
// ---
// --- Example 1 ---
{SinOsc.ar(Summer.kr(Impulse.kr(5), 1.5, 0, 0).poll * 100, 0, 0.1)}.play;

(
{
    var trig = Dust.kr(5);
    var reset = Impulse.kr(0.5);
    SinOsc.ar(Summer.kr(trig, [0.5, 0.25], reset, 1) * 100, 0, 0.1)
}.play;
)
