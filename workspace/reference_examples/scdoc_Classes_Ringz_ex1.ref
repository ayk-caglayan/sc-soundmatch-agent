=== EXAMPLE: scdoc_Classes_Ringz_ex1 ===

DESCRIPTION: A neutral pure_tone sound, with saw_like oscillator character around 553 Hz, featuring very_slow attack and percussive envelope, with chaotic spectral movement, filtered with steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: very_slow
  brightness: neutral
  crest_factor_db: percussive
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 552.7652
  harmonic_decay_rate: -2.1521
  harmonic_regularity: 0.9865
  pitch_clarity: 41.7339
  inharmonicity: 0.7273
  type: saw_like
[filter]
  spectral_slope: -22.4078
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: Ringz Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/Ringz.html
// Tags: Ringz, Classes, filter
// ---
// --- Example 1 ---
{ Ringz.ar(Dust.ar(3, 0.3), 2000, 2) }.play

{ Ringz.ar(WhiteNoise.ar(0.005), 2000, 0.5) }.play

// modulate frequency
{ Ringz.ar(WhiteNoise.ar(0.005), XLine.kr(100, 3000, 10), 0.5) }.play

{ Ringz.ar(Impulse.ar(6, 0, 0.3), XLine.kr(100, 3000, 10), 0.5) }.play

// modulate ring time
{ Ringz.ar(Impulse.ar(6, 0, 0.3), 2000, XLine.kr(4, 0.04, 8)) }.play

// modulate ring time opposite direction
{ Ringz.ar(Impulse.ar(6, 0, 0.3), 2000, XLine.kr(0.04, 4, 8)) }.play

(
{
    var exciter;
    exciter = WhiteNoise.ar(0.001);
    Mix.arFill(10, {
        Ringz.ar(exciter,
        XLine.kr(exprand(100.0, 5000.0), exprand(100.0, 5000.0), 20),
        0.5)
    })
}.play
)
