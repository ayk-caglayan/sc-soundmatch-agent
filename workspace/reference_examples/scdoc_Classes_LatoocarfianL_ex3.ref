// --- Example 3 ---
// randomly modulate all params
(
{ LatoocarfianL.ar(
    SampleRate.ir/4,
    LFNoise2.kr(2, 1.5, 1.5),
    LFNoise2.kr(2, 1.5, 1.5),
    LFNoise2.kr(2, 0.5, 1.5),
    LFNoise2.kr(2, 0.5, 1.5)
) * 0.2 }.play(s);
)
