// --- Example 9 ---
{ VarSaw.ar(VarSaw.kr(VarSaw.kr(0.2,0,0.2,8,10),0,0.2, 400,800),0,0.2,0.1) }.play;
{ VarSaw.ar(VarSaw.kr(0.2, 0, 0.2, 400,800),0,0.2,0.1) }.play;
{ VarSaw.ar(XLine.kr(100,15000,6),0,0.2,0.1) }.play;
