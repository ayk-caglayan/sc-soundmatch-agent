=== EXAMPLE: scdoc_Classes_LorenzTrig_ex2 ===

DESCRIPTION: A very_bright clean sound, with fm_or_inharmonic oscillator character around 156 Hz, featuring punchy attack and dynamic envelope, with chaotic spectral movement, filtered with highpass character, and spectrally dense.

CATEGORIES:
  attack_time: punchy
  brightness: very_bright
  crest_factor_db: dynamic
  envelope_flatness: flat
  harmonic_to_noise_ratio: clean
  spectral_complexity_mean: dense
  spectral_flux_normalized: chaotic
  spectral_slope: highpass
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 156.0130
  harmonic_decay_rate: -1.5958
  harmonic_regularity: 0.3005
  pitch_clarity: 7.2602
  inharmonicity: 0.1427
  type: fm_or_inharmonic
[filter]
  spectral_slope: 9.1647
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: LorenzTrig Example 2
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/LorenzTrig.html
// Tags: LorenzTrig, Classes
// ---
// --- Example 2 ---
{ LorenzTrig.ar(11025, 44100) }.play(s);

// randomly modulate params
(
{ LorenzTrig.ar(
    11025, 44100,
    LFNoise0.kr(1, 2, 10),
    20,
    LFNoise0.kr(1, 1.5, 2),
    0.02
) * 0.2 }.play(s);
)

// as a frequency control
{ SinOsc.ar(Decay.ar(LorenzTrig.ar(1, 8, h:0.02))*800+900)*0.4 }.play(s);
