=== EXAMPLE: scdoc_Classes_FFTTrigger_ex1 ===

DESCRIPTION: A bright pure_tone sound, with complex oscillator character around 172 Hz, featuring very_slow attack and percussive envelope, with chaotic spectral movement, filtered with resonant_steep_rolloff character, and spectrally rich.

CATEGORIES:
  attack_time: very_slow
  brightness: bright
  crest_factor_db: percussive
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: rich
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 172.1103
  harmonic_decay_rate: 1.0396
  harmonic_regularity: 0.2348
  pitch_clarity: 2.5281
  inharmonicity: 0.0000
  type: complex
[filter]
  spectral_slope: -39.4907
  resonance_freq: 8527.1484

SUPERCOLLIDER CODE:
// Title: FFTTrigger Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/FFTTrigger.html
// Tags: FFTTrigger, Classes, spectral
// ---
// --- Example 1 ---
// Reminder: This isn't the intended typical usage! It's OK to do this though.
(
x = {
    var mags, phases, chain, sig;
    // Create simple undulating magnitudes
    mags = { FSinOsc.kr(ExpRand(0.1, 1)).range(0, 1) }.dup(100);
    // Then give them a "rolloff" to make the sound less unpleasant
    mags = mags  * ((1, 0.99 .. 0.01).squared);
    // Let's turn the bins on and off at different rates, I'm *sure* that'll sound interesting
    mags = mags * { LFPulse.kr(2 ** IRand(-3, 5)).range(0, 1) }.dup(100);
    // Let's ignore phase for now
    phases = 0.dup(100);
    chain = FFTTrigger(LocalBuf(512), 0.5);
    // Now we can do the packing
    chain = PackFFT(chain, 512, [mags, phases].flop.flatten, 0, 99, 1);
    sig = IFFT(chain);
    sig.dup
}.play
)
x.free;
b.free;
