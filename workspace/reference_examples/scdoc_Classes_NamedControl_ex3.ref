=== EXAMPLE: scdoc_Classes_NamedControl_ex3 ===

DESCRIPTION: A bright pure_tone sound, with complex oscillator character around 221 Hz, featuring instant attack and sustained envelope, and filtered with resonant_steep_rolloff character.

CATEGORIES:
  attack_time: instant
  brightness: bright
  crest_factor_db: sustained
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: moderate
  spectral_flux_normalized: stable
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 220.6358
  harmonic_decay_rate: -4.9747
  harmonic_regularity: 0.6032
  pitch_clarity: 56.0455
  inharmonicity: 0.0000
  type: complex
[filter]
  spectral_slope: -13.7248
  resonance_freq: 366.0645

SUPERCOLLIDER CODE:
// Title: NamedControl Example 3
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/NamedControl.html
// Tags: NamedControl, Classes
// ---
// --- Example 3 ---
// multiple usage of the same name:
a = { SinOsc.ar(\freq.kr(440, 1.0)) + Saw.ar(\freq.kr(440, 1.0) * 0.5) * 0.1 }.play;

a.set(\freq, 1220);
a.set(\freq, 120);

// with different lag values:
a = { SinOsc.ar(\freq.kr(440).lag(3.5)) + Saw.ar(\freq.kr(440).lag(0.05) * 0.5) * 0.1 }.play;

a.set(\freq, 1220);
a.set(\freq, 120);

// control saved to a variable:
(
a = {
    var freq = \freq.kr(440);
    SinOsc.ar(freq.lag(3.5)) + Saw.ar(freq.lag(0.05) * 0.5) * 0.1;
}.play;
)

a.set(\freq, 1220);
a.set(\freq, 120);
