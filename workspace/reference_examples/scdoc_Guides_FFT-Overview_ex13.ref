=== EXAMPLE: scdoc_Guides_FFT-Overview_ex13 ===

DESCRIPTION: A very_dark mixed sound, with complex characteristics, featuring instant attack and compressed envelope, with static spectral movement, filtered with highpass character, and spectrally dense.

CATEGORIES:
  attack_time: instant
  brightness: very_dark
  crest_factor_db: compressed
  envelope_flatness: very_dynamic
  harmonic_to_noise_ratio: mixed
  spectral_complexity_mean: dense
  spectral_flux_normalized: static
  spectral_slope: highpass
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 0.0000
  harmonic_decay_rate: 0.0000
  harmonic_regularity: 0.0000
  pitch_clarity: 0.0000
  inharmonicity: 0.0000
  type: complex
[filter]
  spectral_slope: 0.0000
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: FFT Overview Example 13
// Author: SC Documentation
// URL: http://doc.sccode.org/Guides/FFT-Overview.html
// Tags: FFT-Overview, Guides, spectral
// ---
// --- Example 13 ---
(
SynthDef("help-multichannel FFT", { |out=0| // bufnum is an array
    var in, chain;
    in = [SinOsc.ar(200, 0, 0.2), WhiteNoise.ar(0.2)];
    chain = FFT(LocalBuf([2048, 2048]), in); // each FFT has a different buffer
    // now we can multichannel expand as normal
    chain = PV_BrickWall(chain, SinOsc.kr(-0.1));

    Out.ar(out, IFFT(chain));
}).play;
)

// or using global buffers

b = { Buffer.alloc(s, 2048, 1) }.dup;

(
SynthDef("help-multichannel FFT", { |out=0, bufnum= #[0, 1]| // bufnum is an array
    var in, chain;
    in = [SinOsc.ar(200, 0, 0.2), WhiteNoise.ar(0.2)];
    chain = FFT(bufnum, in); // each FFT has a different buffer
    // now we can multichannel expand as normal
    chain = PV_BrickWall(chain, SinOsc.kr(-0.1));

    Out.ar(out, IFFT(chain));
}).play(s,[\bufnum, b]);
)

b.free;
