=== EXAMPLE: scdoc_Classes_NLFiltN_ex1 ===

DESCRIPTION: A neutral pure_tone sound, with complex characteristics, featuring punchy attack and compressed envelope, with chaotic spectral movement, filtered with steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: punchy
  brightness: neutral
  crest_factor_db: compressed
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 0.0000
  harmonic_decay_rate: 0.0000
  harmonic_regularity: 0.0000
  pitch_clarity: 0.0000
  inharmonicity: 0.0000
  type: complex
[filter]
  spectral_slope: -13.9332
  resonance_freq: 0.0000

SUPERCOLLIDER CODE:
// Title: NLFiltN Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/NLFiltN.html
// Tags: NLFiltN, Classes
// ---
// --- Example 1 ---
(
{
    NLFiltN.ar(
        LFSaw.ar([120, 180], 0, mul:0.1),
        0.5,
        -0.04,
        0.8,
        0.2,
        LFCub.kr(0.2, [0, 0.5 * pi], 63, 103)
    )
}.play
)

(
{
    NLFiltN.ar(
        LFSaw.ar(XLine.kr([60, 90], [360, 540], 20), 0, mul:0.1),
        0.0,
        0.0,
        0.7,
        0.4,
        LFCub.kr(0.2, [0, 0.5 * pi], 3, 9)
    )
}.play
)

(
// internal mirroring keeps it from blowing up and makes for some gross distortion
// this is a little loud
{
    NLFiltN.ar(
        LFPulse.ar([100, 150], mul:0.1),
        LFNoise2.kr(1).range(0.3, 0.5),
        0.2,
        0.7,
        0.4,
        LFCub.kr(0.2, [0, 0.5 * pi], 100, 400)
    )
}.play
)

(
{
    NLFiltN.ar(
        LFPulse.ar([100, 150], mul:0.1),
        0.35,
        -0.3,
        0.95,
        0.2,
        LFCub.kr(0.2, [0, 0.5 * pi], 50, 100)
    )
}.play
)
