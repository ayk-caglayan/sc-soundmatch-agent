=== EXAMPLE: scdoc_Classes_Lag2_ex1 ===

DESCRIPTION: A very_dark pure_tone sound, with complex oscillator character around 426 Hz, featuring punchy attack and sustained envelope, with chaotic spectral movement, filtered with resonant_steep_rolloff character, and spectrally simple.

CATEGORIES:
  attack_time: punchy
  brightness: very_dark
  crest_factor_db: sustained
  envelope_flatness: flat
  harmonic_to_noise_ratio: pure_tone
  spectral_complexity_mean: simple
  spectral_flux_normalized: chaotic
  spectral_slope: steep_rolloff
  temporal_centroid: balanced

SYNTHESIS CONCEPTS (key values):
[oscillator]
  fundamental_freq: 426.2402
  harmonic_decay_rate: -15.4691
  harmonic_regularity: 0.5012
  pitch_clarity: 148.7724
  inharmonicity: 0.0290
  type: complex
[filter]
  spectral_slope: -5.1819
  resonance_freq: 430.6641

SUPERCOLLIDER CODE:
// Title: Lag2 Example 1
// Author: SC Documentation
// URL: http://doc.sccode.org/Classes/Lag2.html
// Tags: Lag2, Classes, envelope
// ---
// --- Example 1 ---
(
// used to lag pitch
{
    SinOsc.ar(        // sine wave
        Lag2.kr(            // lag the modulator
            LFPulse.kr(4, 0, 0.5, 50, 400),    // frequency modulator
            Line.kr(0, 1, 15)                // modulate lag time
        ),
        0,    // phase
        0.3    // sine amplitude
    )
}.play
)
